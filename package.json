    "fumadocs-mdx": "15.0.11",
    "fumadocs-registry": "^0.3.2",
    "fumadocs-ui": "16.9.3",
    "isbot": "^5.1.40",
    "lucide-react": "^1.17.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router": "^7.16.0",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@react-router/dev": "^7.16.0",
    "@tailwindcss/vite": "^4.3.0",
    "@types/mdx": "^2.0.13",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.16",
    "@types/react-dom": "^19.2.3",
    "fs-extra": "^11.3.5",
    "react-router-devtools": "^6.2.1",
