{
  "name": "litefy-fuma",
  "private": true,
  "type": "module",
  "scripts": {
    "prebuild": "pnpm node scripts/copy-registry.js",
    "build": "react-router build",
    "dev": "react-router dev",
    "start": "serve ./build/client --config ../../serve.json",
    "types:check": "react-router typegen && fumadocs-mdx && tsc --noEmit",
